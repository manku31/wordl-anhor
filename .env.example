# Pooled connection (PgBouncer) — used by Prisma Client at runtime
# Get this from your Neon project dashboard (pooler connection string)
DATABASE_URL='postgresql://<user>:<password>@<pooler-host>/<db>?sslmode=require&pgbouncer=true&connection_limit=1'

# Direct connection — used by Prisma CLI for migrations / db push only
# Same as above but without the -pooler suffix in the host
DIRECT_DATABASE_URL='postgresql://<user>:<password>@<direct-host>/<db>?sslmode=require'

# Secret for signing JWT session tokens
# Generate one with: openssl rand -hex 32
SESSION_SECRET='your-secret-here'

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY='sk-...'

# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY='AIza...'

# DeepSeek API key — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY='sk-...'
